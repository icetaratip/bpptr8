{
  "name": "bpptr8-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:api\" \"npm:web\"",
    "web": "vite --host --port 5174",
    "api": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "scrape": "node -e \"import('./server/scraper.mjs').then(m=>m.scrapeNewsFeed({limit:3}).then(d=>console.log(JSON.stringify(d,null,2))))\""
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
